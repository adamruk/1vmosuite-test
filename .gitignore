# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# PyInstaller
build/
dist/
*.spec.bak

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Bundled ffmpeg binaries (huge, reproducible from your bundling setup).
# Shared-build DLLs are large (~154 MB) and provisioned by setup.ps1 on clone,
# so they stay out of git alongside the .exe wrappers.
ffmpeg/ffmpeg.exe
ffmpeg/ffprobe.exe
ffmpeg/*.dll

# Runtime logs / user data
*.log
!tests/smoke-*.log

# Runtime config files (written by apps on every close)
# Filenames match each app's CONFIG_FILE: auto_render -> renderer, cutter,
# merge, mixer. (mixer.py:305 writes config_video_mixer.json; the old
# config_video_merger.json was never written by any app and is dropped.)
config_video_renderer.json
config_video_cutter.json
config_video_merge.json
config_video_mixer.json
config_video_*.json.bak

# Claude Code local prefs (personal, not project)
.claude/settings.local.json
.claude/cache/

# Claude Code worktrees + MAIN<->VERIFY GPU-coordination state (per-machine, transient)
.claude/worktrees/
.agent-status/

# VMAF validation working files — large binaries regenerable via the orchestrator script.
# JSON outputs (results.json + per-pairing vmaf logs) ARE committed for machine inspection.
benchmarks/_vmaf_work/*.mp4

# Portable mode user data dir (created when portable.txt is present)
UserData/

# Portable mode sentinel (per-developer, NOT shipped)
portable.txt

# Synthetic test sources for stress tests (regenerable via ffmpeg -f lavfi)
test_source_*.mp4
